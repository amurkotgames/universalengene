--// TRUE ANTI FALL DAMAGE (MINECRAFT CLONE FIX)
local antiFallEnabled = false

local function antiFallLoop()
    task.spawn(function()
        while antiFallEnabled do
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    -- Reset fall distance used by Minecraft scripts
                    root.FallingDown = false
                    root.Velocity = Vector3.new(root.Velocity.X, math.max(root.Velocity.Y, -10), root.Velocity.Z)
                end
            end
            task.wait(0.05)
        end
    end)
end

