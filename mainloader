-- VR9 ULTRA FLING v5 (SUPER SPIN + UNESCAPABLE + SKY LAUNCH)
---------------------------------------------------------------------

local targetPlayer = nil
local flingActive = false
local flingConnection = nil
local originalFlingPosition = nil
local FlingToggle

local PlayerDropdown = TrollTab:CreateDropdown({
    Name = "Select Fling Target",
    Options = getPlayerNames(),
    CurrentOption = {""},
    MultipleOptions = false,
    Flag = "TargetPlayer",
    Callback = function(option)
        local found = Players:FindFirstChild(option[1] or "")
        targetPlayer = nil
        flingActive = false

        if not found or found == LocalPlayer then
            if FlingToggle then FlingToggle:Set(false) end
            Rayfield:Notify({
                Title = "Invalid Target",
                Content = "Choose a different player.",
                Duration = 4
            })
            return
        end

        targetPlayer = found

        Rayfield:Notify({
            Title = "Target Selected",
            Content = "Enable Ultra Fling to launch them.",
            Duration = 4
        })
    end,
})

local function startFling()
    if flingActive then return end
    flingActive = true

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        originalFlingPosition = root.CFrame
    end

    flingConnection = RunService.Heartbeat:Connect(function()
        if not flingActive or not targetPlayer then return end

        local targetChar = targetPlayer.Character
        local localChar = LocalPlayer.Character
        if not targetChar or not localChar then return end

        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
        local hum = localChar:FindFirstChild("Humanoid")

        if not targetRoot or not localRoot or not hum then return end

        hum.PlatformStand = true
        localRoot.CanCollide = true
        targetRoot.CanCollide = true

        localRoot.CFrame = targetRoot.CFrame

        localRoot.RotVelocity = Vector3.new(0, 5000, 0)
        localRoot.AssemblyAngularVelocity = Vector3.new(0, 5000, 0)

        localRoot.Velocity = Vector3.new(
            math.random(-20, 20),
            1200,
            math.random(-20, 20)
        )
    end)
end

local function stopFling()
    flingActive = false

    if flingConnection then
        flingConnection:Disconnect()
        flingConnection = nil
    end

    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")

        if root then
            root.Velocity = Vector3.zero
            root.RotVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
        if hum then
            hum.PlatformStand = false
        end
    end

    if originalFlingPosition then
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = originalFlingPosition
        end
    end
end

FlingToggle = TrollTab:CreateToggle({
    Name = "Enable Ultra Fling v5 (Super Spin)",
    CurrentValue = false,
    Flag = "FlingToggle",
    Callback = function(v)
        if v then
            if targetPlayer then
                startFling()
            else
                Rayfield:Notify({
                    Title = "No Target",
                    Content = "Select a player first!",
                    Duration = 4
