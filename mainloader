local function startFly()
    if flying then return end
    flying = true

    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local root = character:WaitForChild("HumanoidRootPart")

    humanoid.PlatformStand = true
    humanoid.AutoRotate = false

    -- Create BodyVelocity (this stops falling completely)
    bv = Instance.new("BodyVelocity")
    bv.Name = "FlyBV"
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)  -- Very strong
    bv.Velocity = Vector3.zero
    bv.Parent = root

    -- GUI (WASD buttons)
    gui = Instance.new("ScreenGui")
    gui.Parent = game.CoreGui
    gui.ResetOnSpawn = false

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 160, 0, 160)
    frame.Position = UDim2.new(0.05, 0, 0.45, 0)
    frame.BackgroundTransparency = 1
    frame.Active = true
    frame.Draggable = true
    frame.Parent = gui

    local function makeButton(name, x, y)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0, 50, 0, 50)
        b.Position = UDim2.new(0, x, 0, y)
        b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
        b.TextScaled = true
        b.Font = Enum.Font.GothamBold
        b.Text = name
        b.Parent = frame
        return b
    end

    local W = makeButton("W", 55, 0)
    local A = makeButton("A", 0, 55)
    local S = makeButton("S", 55, 110)
    local D = makeButton("D", 110, 55)

    local function bind(btn, vec)
        btn.MouseButton1Down:Connect(function() moveVector = vec end)
        btn.MouseButton1Up:Connect(function() moveVector = Vector3.zero end)
        btn.MouseLeave:Connect(function() moveVector = Vector3.zero end)
    end

    bind(W, Vector3.new(0, 0, -1))
    bind(S, Vector3.new(0, 0, 1))
    bind(A, Vector3.new(-1, 0, 0))
    bind(D, Vector3.new(1, 0, 0))

    -- Main Fly Loop
    flyConnection = RunService.RenderStepped:Connect(function()
        if not flying or not bv then return end

        local cam = workspace.CurrentCamera
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local move = cam.CFrame:VectorToWorldSpace(moveVector)

        if move.Magnitude > 0 then
            bv.Velocity = move.Unit * speed
        else
            bv.Velocity = Vector3.new(0, 0, 0)  -- Hold position perfectly
        end

        -- Face camera direction
        rootPart.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + cam.CFrame.LookVector)
    end)
end

