local jumpscareActive = false
local jumpscareTarget = nil
local jumpscareConnection = nil
local originalAppearance = {}
local creepySound = nil
local originalJumpscarePosition = nil

-- Save original appearance
local function storeAppearance()
    local char = LocalPlayer.Character
    if not char then return end

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalAppearance[part] = {
                Color = part.Color,
                Material = part.Material,
                Transparency = part.Transparency
            }
        end
    end
end

-- Restore appearance
local function restoreAppearance()
    for part, data in pairs(originalAppearance) do
        if part and part.Parent then
            part.Color = data.Color
            part.Material = data.Material
            part.Transparency = data.Transparency
        end
    end
end

-- Turn character black
local function blackoutCharacter()
    local char = LocalPlayer.Character
    if not char then return end

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Color = Color3.new(0,0,0)
            part.Material = Enum.Material.SmoothPlastic
            part.Transparency = 0
        end
    end
end

-- Creepy sound
local function createCreepySound()
    local char = LocalPlayer.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    creepySound = Instance.new("Sound")
    creepySound.SoundId = "rbxassetid://9123649421"
    creepySound.Volume = 3
    creepySound.Looped = true
    creepySound.Parent = root
    creepySound:Play()
end

local function stopCreepySound()
    if creepySound then
        creepySound:Stop()
        creepySound:Destroy()
        creepySound = nil
    end
end

-- Main jumpscare loop
local function startJumpscare()
    if jumpscareActive then return end
    jumpscareActive = true

    local localChar = LocalPlayer.Character
    if not localChar then return end

    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end

    -- Save original position BEFORE jumpscare
    originalJumpscarePosition = localRoot.CFrame

    storeAppearance()
    blackoutCharacter()
    createCreepySound()

    jumpscareConnection = RunService.Heartbeat:Connect(function()
        if not jumpscareActive or not jumpscareTarget then return end

        local targetChar = jumpscareTarget.Character
        local localChar = LocalPlayer.Character
        if not targetChar or not localChar then return end

        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end

        -- ⭐ FIXED: appear IN FRONT of the player
        localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 2)

        -- Glitch effect
        localRoot.CFrame = localRoot.CFrame * CFrame.Angles(
            math.random(-2,2) * 0.01,
            math.random(-2,2) * 0.01,
            math.random(-2,2) * 0.01
        )
    end)
end

local function stopJumpscare()
    jumpscareActive = false

    if jumpscareConnection then
        jumpscareConnection:Disconnect()
        jumpscareConnection = nil
    end

    stopCreepySound()
    restoreAppearance()

    -- ⭐ FIXED: return to original position
    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and originalJumpscarePosition then
            root.CFrame = originalJumpscarePosition
        end
    end
end

