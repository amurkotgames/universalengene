-- VR9 INVISIBLE MODE v3 (FULL INVISIBILITY + FULL RESTORE)
---------------------------------------------------------------------

local invisibleEnabled = false
local storedTransparency = {}
local storedLocalTransparency = {}
local storedAccessories = {}
local storedDecals = {}

local function setInvisible(state)
    local char = LocalPlayer.Character
    if not char then return end

    for _, obj in ipairs(char:GetDescendants()) do

        -- BODY PARTS
        if obj:IsA("BasePart") then

            -- Save original transparency
            if storedTransparency[obj] == nil then
                storedTransparency[obj] = obj.Transparency
            end

            -- Save original LocalTransparencyModifier
            if storedLocalTransparency[obj] == nil then
                storedLocalTransparency[obj] = obj.LocalTransparencyModifier
            end

            if state then
                obj.Transparency = 1
                obj.LocalTransparencyModifier = 1
            else
                obj.Transparency = storedTransparency[obj]
                obj.LocalTransparencyModifier = storedLocalTransparency[obj]
            end
        end

        -- ACCESSORIES
        if obj:IsA("Accessory") then
            local handle = obj:FindFirstChild("Handle")
            if handle then
                if storedAccessories[obj] == nil then
                    storedAccessories[obj] = {
                        Transparency = handle.Transparency,
                        LocalTransparencyModifier = handle.LocalTransparencyModifier
                    }
                end

                if state then
                    handle.Transparency = 1
                    handle.LocalTransparencyModifier = 1
                else
                    handle.Transparency = storedAccessories[obj].Transparency
                    handle.LocalTransparencyModifier = storedAccessories[obj].LocalTransparencyModifier
                end
            end
        end

        -- FACE / DECALS
        if obj:IsA("Decal") then
            if storedDecals[obj] == nil then
                storedDecals[obj] = obj.Transparency
            end

            if state then
                obj.Transparency = 1
            else
                obj.Transparency = storedDecals[obj]
            end
        end
    end

    -- Restore tables when turning off
    if not state then
        storedTransparency = {}
        storedLocalTransparency = {}
        storedAccessories = {}
        storedDecals = {}
    end
end

