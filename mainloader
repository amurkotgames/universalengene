local godmodeEnabled = false
local godLoop = nil
local diedConnection = nil

local function protectHumanoid(hum)
    -- Infinite health
    hum.MaxHealth = math.huge
    hum.Health = math.huge

    -- Block death states
    pcall(function()
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    end)

    -- Anti-BreakJoints
    hum.BreakJointsOnDeath = false

    -- Anti-Died event
    if diedConnection then diedConnection:Disconnect() end
    diedConnection = hum.Died:Connect(function()
        if not godmodeEnabled then return end

        task.wait(0.05)
        hum.Health = math.huge
        hum.MaxHealth = math.huge
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end)
end

local function enableGodmode()
    local char = LocalPlayer.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    protectHumanoid(hum)

    -- Constant anti-kill loop
    if godLoop then godLoop:Disconnect() end
    godLoop = RunService.Heartbeat:Connect(function()
        if not godmodeEnabled then return end

        local char = LocalPlayer.Character
        if not char then return end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end

        -- Reapply infinite health
        if hum.Health < hum.MaxHealth then
            hum.MaxHealth = math.huge
            hum.Health = math.huge
        end

        -- Anti forced death
        if hum:GetState() == Enum.HumanoidStateType.Dead then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            hum.Health = math.huge
        end

        -- Anti server kill attempts
        if hum.Health <= 0 then
            hum.Health = math.huge
        end
    end)
end

local function disableGodmode()
    godmodeEnabled = false
    if godLoop then godLoop:Disconnect() end
    if diedConnection then diedConnection:Disconnect() end
end

HacksTab:CreateToggle({
    Name = "Godmode",
    CurrentValue = false,
    Flag = "GodmodeToggle",
    Callback = function(v)
        godmodeEnabled = v
        if v then enableGodmode() else disableGodmode() end
    end,
})

