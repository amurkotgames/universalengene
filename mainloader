-- Hash system (privacy-safe)
local function HashUsername(username)
    local encoded = HttpService:JSONEncode({u = username})
    local hash = encoded:gsub("%W", ""):sub(1, 16)
    return hash
end

local LocalPlayer = Players.LocalPlayer
local player = LocalPlayer
local camera = Camera

local function sendEmbed(webhookUrl, title, message, color)
    local hashed = HashUsername(LocalPlayer.Name)

    local data = {
        ["username"] = "VR9 Hub",
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = "**From:** " .. hashed .. "\n**Message:** " .. message,
            ["type"] = "rich",
            ["color"] = color,
            ["footer"] = {
                ["text"] = "VR9 Feedback System • " .. os.date("%Y-%m-%d %H:%M:%S")
            }
        }}
    }

    local json = HttpService:JSONEncode(data)

    request({
        Url = webhookUrl,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = json
    })
end

