---------------------------------------------------------------------
-- VR9 HELL CIRCLE v4 (Fixed + More Stable)
---------------------------------------------------------------------

local hellcircleActive = false
local hellcircleConnection = nil
local hellcircleClones = {}
local hellcircleTarget = nil
local originalPosition = nil

-- Clone creator
local function createClone()
    local char = LocalPlayer.Character
    if not char then return end

    local clone = char:Clone()
    clone.Parent = workspace
    clone.Name = LocalPlayer.Name .. "_Clone"

    local root = clone:FindFirstChild("HumanoidRootPart") 
              or clone:FindFirstChild("Torso") 
              or clone:FindFirstChild("UpperTorso")

    if root and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        root.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
    end

    local hum = clone:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = true
        hum:ChangeState(Enum.HumanoidStateType.Physics)
    end

    for _, part in ipairs(clone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
            part.Anchored = false
        end
    end

    return clone
end

local function removeClones()
    for _, c in ipairs(hellcircleClones) do
        if c and c.Parent then c:Destroy() end
    end
    hellcircleClones = {}
end

local function startHellCircle()
    if hellcircleActive then return end
    hellcircleActive = true

    if not hellcircleTarget then
        Rayfield:Notify({Title = "Error", Content = "No target selected!", Duration = 4})
        hellcircleActive = false
        return
    end

    -- Wait for target's character
    if not hellcircleTarget.Character then
        Rayfield:Notify({Title = "Target Loading", Content = "Waiting for target to spawn...", Duration = 4})
        hellcircleActive = false
        return
    end

    local localChar = LocalPlayer.Character
    if localChar then
        local root = localChar:FindFirstChild("HumanoidRootPart")
        if root then originalPosition = root.CFrame end
    end

    -- Create clones
    for i = 1, 6 do
        local clone = createClone()
        if clone then table.insert(hellcircleClones, clone) end
    end

    hellcircleConnection = RunService.Heartbeat:Connect(function()
        if not hellcircleActive or not hellcircleTarget then return end

        local targetChar = hellcircleTarget.Character
        local localChar = LocalPlayer.Character

        if not targetChar or not localChar then return end

        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
        local hum = localChar:FindFirstChild("Humanoid")

        if not targetRoot or not localRoot or not hum then return end

        hum.PlatformStand = true
        localRoot.CanCollide = false

        local angle = tick() * 10  -- Faster spin
        local radius = 9

        -- Main player spinning
        localRoot.CFrame = CFrame.new(
            targetRoot.Position.X + math.cos(angle) * radius,
            targetRoot.Position.Y + 3,
            targetRoot.Position.Z + math.sin(angle) * radius
        ) * CFrame.Angles(0, angle * 3, 0)

        -- Clones spinning
        for i, clone in ipairs(hellcircleClones) do
            local cloneRoot = clone:FindFirstChild("HumanoidRootPart") 
                           or clone:FindFirstChild("Torso") 
                           or clone:FindFirstChild("UpperTorso")

            if cloneRoot then
                local offset = (i / #hellcircleClones) * math.pi * 2
                local cloneAngle = angle + offset

                cloneRoot.CFrame = CFrame.new(
                    targetRoot.Position.X + math.cos(cloneAngle) * radius,
                    targetRoot.Position.Y + 3,
                    targetRoot.Position.Z + math.sin(cloneAngle) * radius
                ) * CFrame.Angles(0, cloneAngle * 3, 0)
            end
        end
    end)
end

local function stopHellCircle()
    hellcircleActive = false

    if hellcircleConnection then
        hellcircleConnection:Disconnect()
        hellcircleConnection = nil
    end

    removeClones()

    -- Return to original position
    if originalPosition then
        local localChar = LocalPlayer.Character
        if localChar then
            local root = localChar:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = originalPosition
            end
        end
    end
end

